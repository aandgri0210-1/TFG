# Django Configuration
DJANGO_SECRET_KEY=your-secret-key-here-change-this
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1,your-domain.com,www.your-domain.com
DJANGO_SECURE_SSL_REDIRECT=1
DJANGO_ENV=production

# Database Configuration (PostgreSQL)
DB_ENGINE=postgresql
POSTGRES_DB=tfg_marketplace
POSTGRES_USER=tfg_user
POSTGRES_PASSWORD=change-this-to-secure-password
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Geolocation API (Get from https://www.geoapify.com)
GEOAPIFY_API_KEY=a98b0f771c79481aa3d121b1a6a1370b

# Email Configuration (Gmail or your SMTP provider)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=noreply@your-domain.com

# PRODUCTION DEPLOYMENT INSTRUCTIONS:
# 1. Generate a new DJANGO_SECRET_KEY: python -c "import secrets; print(secrets.token_hex(32))"
# 2. Generate PostgreSQL password: python -c "import secrets; print(secrets.token_urlsafe(32))"
# 3. Update DJANGO_ALLOWED_HOSTS with your actual domain names
# 4. Add GEOAPIFY_API_KEY from https://www.geoapify.com
# 5. Configure real SMTP credentials (EMAIL_HOST_USER, EMAIL_HOST_PASSWORD)
# 6. Store this file securely and NEVER commit to version control
# 7. For production, use a secrets management system (AWS Secrets Manager, HashiCorp Vault, etc.)
